SemverQuery(
    id: "partial_ord_non_exhaustive_enum_variants_reordered",
    human_readable_name: "variants reordered in #[derive(PartialOrd)] #[non_exhaustive] enum",
    description: "A public #[non_exhaustive] enum that derives PartialOrd had its variants reordered relative to each other, which changes its ordering behavior. Merely inserting new variants between existing ones without changing their relative order does not trigger this lint.",
    required_update: Major,
    lint_level: Warn,
    reference_link: Some("https://doc.rust-lang.org/std/cmp/trait.PartialOrd.html#derivable"),
    query: r#"
    {
        CrateDiff {
            baseline {
                item {
                    ... on Enum {
                        visibility_limit @filter(op: "=", value: ["$public"])

                        impl {
                            negative @filter(op: "=", value: ["$false"])
                            attrs @filter(op: "contains", value: ["$derived"])

                            implemented_trait {
                                trait {
                                    canonical_path {
                                        path @filter(op: "=", value: ["$partial_ord"])
                                    }
                                }
                            }
                        }

                        importable_path {
                            path @tag @output
                            public_api @filter(op: "=", value: ["$true"])
                        }

                        # Variant A: the one whose reordering we report.
                        variant {
                            variant_name: name @output @tag
                            public_api_eligible @filter(op: "=", value: ["$true"])
                            position @output @tag
                        }

                        # Variant B: a witness that was AFTER variant A in baseline.
                        variant {
                            witness_name: name @tag
                                @filter(op: "!=", value: ["%variant_name"])
                            public_api_eligible @filter(op: "=", value: ["$true"])
                            position @filter(op: ">", value: ["%position"])
                        }
                    }
                }
            }
            current {
                item {
                    ... on Enum {
                        visibility_limit @filter(op: "=", value: ["$public"])
                        attrs @filter(op: "contains", value: ["$non_exhaustive"])
                        name @output

                        impl {
                            negative @filter(op: "=", value: ["$false"])
                            attrs @filter(op: "contains", value: ["$derived"])

                            implemented_trait {
                                trait {
                                    canonical_path {
                                        path @filter(op: "=", value: ["$partial_ord"])
                                    }
                                }
                            }
                        }

                        importable_path {
                            path @filter(op: "=", value: ["%path"])
                            public_api @filter(op: "=", value: ["$true"])
                        }

                        # Variant A in current: get its new position.
                        variant {
                            name @filter(op: "=", value: ["%variant_name"])
                            public_api_eligible @filter(op: "=", value: ["$true"])
                            new_position: position @tag @output

                            span_: span @optional {
                                filename @output
                                begin_line @output
                                end_line @output
                            }
                        }

                        # Variant B is now BEFORE variant A: an inversion.
                        variant {
                            name @filter(op: "=", value: ["%witness_name"])
                            public_api_eligible @filter(op: "=", value: ["$true"])
                            position @filter(op: "<", value: ["%new_position"])
                        }
                    }
                }
            }
        }
    }"#,
    arguments: {
        "public": "public",
        "derived": "#[automatically_derived]",
        "false": false,
        "true": true,
        "non_exhaustive": "#[non_exhaustive]",
        "partial_ord": ["core", "cmp", "PartialOrd"],
    },
    error_message: "A public #[non_exhaustive] enum that derives PartialOrd had its variants reordered relative to each other. #[derive(PartialOrd)] uses the enum variant order to set the enum's ordering behavior, so this change may break downstream code that relies on the previous order.",
    per_result_error_template: Some("{{name}}::{{variant_name}} moved from position {{position}} to {{new_position}}, in {{span_filename}}:{{span_begin_line}}"),
)
